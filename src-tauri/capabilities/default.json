{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default local StackDrop permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "sql:default",
    "sql:allow-execute",
    "fs:allow-read-file",
    "fs:allow-read-text-file",
    {
      "identifier": "fs:scope",
      "allow": [{ "path": "$HOME/**" }]
    },
    "fs:allow-watch",
    "fs:allow-unwatch"
  ]
}
